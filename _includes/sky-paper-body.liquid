{% assign ordered = site.tutorials | sort: 'title' %}
{% assign thumbs = "/images/359239/figure-1.jpg" | split: "," %}
{% assign all_tags = "" | split: "" %}
{% for post in ordered %}{% for tag in post.tags %}{% assign all_tags = all_tags | push: tag %}{% endfor %}{% endfor %}
{% assign all_tags = all_tags | uniq | sort %}

<header class="sky-header">
<div class="sky-header-row">
<div class="sky-header-copy">
<h1>{{ include.title }}</h1>
<p class="sky-sub">{{ include.subtitle }}</p>
</div>
<div class="sky-view-toggle" role="group" aria-label="Toggle post view">
<button type="button" class="sky-view-btn sky-view-active" data-view="grid" aria-label="Grid view"><i class="ti ti-layout-grid"></i></button>
<button type="button" class="sky-view-btn" data-view="list" aria-label="List view"><i class="ti ti-list"></i></button>
</div>
</div>
<p class="sky-count" data-total="{{ ordered | size }}">{{ ordered | size }} total posts.</p>
</header>

<div class="sky-search">
<span class="sky-search-icon"><i class="ti ti-search"></i></span>
<input type="text" class="sky-search-input" placeholder="Search posts..." aria-label="Search posts" autocomplete="off">
<button type="button" class="sky-search-clear" aria-label="Clear search" hidden><i class="ti ti-x"></i></button>
</div>

<div class="sky-chips">
{% for tag in all_tags %}<button type="button" class="sky-chip" data-tag="{{ tag | downcase }}">{{ tag }}</button>{% endfor %}
</div>

<p class="sky-empty" hidden>No posts match your search.</p>

<div class="sky-posts" data-view="grid">

<div class="sky-grid">
{% for post in ordered %}
{% assign read_time = post.content | number_of_words | divided_by: 180 | plus: 1 %}
{% assign thumb = thumbs[forloop.index0] %}
{% capture tagstr %}{% for tag in post.tags %}{{ tag | downcase }} {% endfor %}{% endcapture %}
<a class="sky-card" href="{{ post.url | relative_url }}" data-tags="{{ tagstr | strip }}" data-search="{{ post.title | append: ' ' | append: post.description | append: ' ' | append: tagstr | strip_html | downcase | escape }}">
<div class="sky-card-thumb"><img src="{{ thumb | relative_url }}" alt="{{ post.title }}" loading="lazy"></div>
<div class="sky-card-body">
<div class="sky-card-tags">{% for tag in post.tags limit: 2 %}<span data-tag="{{ tag | downcase }}">{{ tag }}</span>{% endfor %}</div>
<h3>{{ post.title }}</h3>
<p>{{ post.description | strip_html | truncate: 130 }}</p>
<div class="sky-card-meta"><span>{{ read_time }} min read</span><span class="sky-arrow"><i class="ti ti-arrow-right"></i></span></div>
</div>
</a>
{% endfor %}
</div>

<div class="sky-list">
{% for post in ordered %}
{% assign read_time = post.content | number_of_words | divided_by: 180 | plus: 1 %}
{% assign thumb = thumbs[forloop.index0] %}
{% capture tagstr %}{% for tag in post.tags %}{{ tag | downcase }} {% endfor %}{% endcapture %}
<a class="sky-row" href="{{ post.url | relative_url }}" data-tags="{{ tagstr | strip }}" data-search="{{ post.title | append: ' ' | append: post.description | append: ' ' | append: tagstr | strip_html | downcase | escape }}">
<div class="sky-row-thumb"><img src="{{ thumb | relative_url }}" alt="{{ post.title }}" loading="lazy"></div>
<div class="sky-row-body">
<h3>{{ post.title }}</h3>
<p>{{ post.description | strip_html | truncate: 160 }}</p>
<div class="sky-row-meta"><span class="sky-row-tags">{% for tag in post.tags limit: 2 %}<span data-tag="{{ tag | downcase }}">{{ tag }}</span>{% endfor %}</span><span class="sky-row-dot"></span><span>{{ read_time }} min read</span></div>
</div>
</a>
{% endfor %}
</div>

</div>
